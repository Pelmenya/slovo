# =============================================================================
# SLOVO — AI Platform Environment
# =============================================================================
# Скопируй в .env и заполни значения:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WORKER_CONCURRENCY=5
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# PostgreSQL (pgvector)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=slovo
POSTGRES_PASSWORD=slovo_dev_password_change_me
POSTGRES_DB=slovo
DATABASE_URL=postgresql://slovo:slovo_dev_password_change_me@localhost:5432/slovo?schema=public

# -----------------------------------------------------------------------------
# Valkey (Redis-compatible)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=slovo
RABBITMQ_PASSWORD=slovo_dev_password_change_me
RABBITMQ_URL=amqp://slovo:slovo_dev_password_change_me@localhost:5672

# -----------------------------------------------------------------------------
# Flowise
# -----------------------------------------------------------------------------
FLOWISE_PORT=3000
FLOWISE_API_URL=http://localhost:3000
# FLOWISE_CHATFLOW_ID=

# -----------------------------------------------------------------------------
# Langfuse (LLM observability)
# -----------------------------------------------------------------------------
LANGFUSE_PORT=3100
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_POSTGRES_PORT=5433

# -----------------------------------------------------------------------------
# Dev UIs
# -----------------------------------------------------------------------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@slovo.local
PGADMIN_DEFAULT_PASSWORD=admin
REDIS_COMMANDER_PORT=8081

# -----------------------------------------------------------------------------
# LLM провайдеры
# -----------------------------------------------------------------------------
# Claude (основная модель)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# OpenAI (опционально — для сравнений и fallback)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Безопасность (JWT, API Keys — заполнять в production)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100
