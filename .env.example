# =============================================================================
# SLOVO — AI Platform Environment
# =============================================================================
# Скопируй в .env и заполни значения:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Приложение
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3101
WORKER_CONCURRENCY=5
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# PostgreSQL (pgvector)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=slovo
POSTGRES_PASSWORD=slovo_dev_password_change_me
POSTGRES_DB=slovo
DATABASE_URL=postgresql://slovo:slovo_dev_password_change_me@localhost:5433/slovo?schema=public

# -----------------------------------------------------------------------------
# Valkey (Redis-compatible)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=slovo
RABBITMQ_PASSWORD=slovo_dev_password_change_me
RABBITMQ_URL=amqp://slovo:slovo_dev_password_change_me@localhost:5672

# -----------------------------------------------------------------------------
# Flowise
# -----------------------------------------------------------------------------
FLOWISE_PORT=3130
FLOWISE_API_URL=http://localhost:3130
# FLOWISE_CHATFLOW_ID=
# Bearer token из Flowise UI → API Keys → + Create Key.
# Используется libs/mcp-flowise (MCP-сервер для Claude Code) и любым slovo-кодом
# который ходит в Flowise REST. Если пуст — RBAC-protected endpoint'ы вернут 401.
FLOWISE_API_KEY=

# -----------------------------------------------------------------------------
# Langfuse (LLM observability)
# -----------------------------------------------------------------------------
LANGFUSE_PORT=3100
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_POSTGRES_PORT=5434
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=langfuse_dev_password_change_me
LANGFUSE_POSTGRES_DB=langfuse
# Сгенерировать: openssl rand -hex 32  (все три разные)
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# S3 / MinIO (knowledge base source storage)
# -----------------------------------------------------------------------------
# Dev: MinIO в docker-compose, эндпоинт http://localhost:9010, path-style URL.
# Prod: AWS S3 (S3_ENDPOINT оставить пустым — SDK выберет регион сам), либо
# managed S3-совместимый (DigitalOcean Spaces, Cloudflare R2 — свой endpoint).
S3_ENDPOINT=http://localhost:9010
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=slovo_dev_minio_password_change_me
S3_BUCKET=slovo-sources
# Catalog images (vision-catalog-search) — feeder'ы пишут сюда картинки
# товаров, slovo-api генерит presigned URL для /catalog/search/* response.
# Отдельный от knowledge bucket'а (другой IAM-scope, см. ADR-007).
S3_CATALOG_BUCKET=slovo-datasets
# Dev (MinIO) = true (path-style: http://endpoint/bucket/key).
# Prod (AWS S3 / Cloudflare R2) = false (virtual-hosted: https://bucket.s3.region.amazonaws.com/key).
S3_FORCE_PATH_STYLE=true

# MinIO контейнер (dev-only)
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=slovo_dev_minio_password_change_me

# -----------------------------------------------------------------------------
# Dev UIs
# -----------------------------------------------------------------------------
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@slovo.local
PGADMIN_DEFAULT_PASSWORD=admin
REDIS_COMMANDER_PORT=8081

# -----------------------------------------------------------------------------
# LLM провайдеры
# -----------------------------------------------------------------------------
# Claude (основная модель)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# OpenAI (опционально — для сравнений и fallback)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Безопасность (JWT, API Keys — заполнять в production)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100
