// Главный файл схемы — generators + datasource.
// Доменные модели живут в соседних файлах (user.prisma, water-analysis.prisma и т.д.).
//
// После изменений:
//   npm run prisma:generate              — обновить клиент
//   npm run prisma:migrate:dev --name X  — создать миграцию

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

generator nestjsDto {
    provider                        = "prisma-generator-nestjs-dto"
    output                          = "../../libs/database/src/generated"
    outputToNestJsResourceStructure = "true"
    classValidation                 = "true"
    noDependencies                  = "false"
    exportRelationModifierClasses   = "true"
    reExport                        = "true"
    createDtoPrefix                 = "Create"
    updateDtoPrefix                 = "Update"
    dtoSuffix                       = "Dto"
    entityPrefix                    = ""
    entitySuffix                    = ""
    fileNamingStyle                 = "kebab"
}

datasource db {
    provider   = "postgresql"
    extensions = [vector, pg_trgm, uuidOssp(map: "uuid-ossp"), pgcrypto]
}
