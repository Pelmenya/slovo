// Prisma schema — Slovo AI Platform
//
// Документация:
//   https://www.prisma.io/docs
//
// После изменений:
//   npm run prisma:generate              — обновить клиент
//   npm run prisma:migrate:dev --name X  — создать миграцию

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["postgresqlExtensions"]
}

generator nestjsDto {
    provider                        = "prisma-generator-nestjs-dto"
    output                          = "../libs/database/src/generated"
    outputToNestJsResourceStructure = "true"
    classValidation                 = "true"
    noDependencies                  = "false"
    exportRelationModifierClasses   = "true"
    reExport                        = "true"
    createDtoPrefix                 = "Create"
    updateDtoPrefix                 = "Update"
    dtoSuffix                       = "Dto"
    entityPrefix                    = ""
    entitySuffix                    = ""
    fileNamingStyle                 = "kebab"
}

datasource db {
    provider   = "postgresql"
    extensions = [vector, pg_trgm, uuidOssp(map: "uuid-ossp"), pgcrypto]
}

// =============================================================================
// Базовая модель для тестирования окружения
// Далее будут доменные модели (water-analysis, notes-rag и т.д.)
// =============================================================================

model HealthCheck {
    id        String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
    service   String            @db.VarChar(64)
    status    HealthCheckStatus
    createdAt DateTime          @default(now()) @map("created_at")

    @@index([service, createdAt])
    @@map("health_checks")
}

enum HealthCheckStatus {
    ok
    degraded
    down

    @@map("health_check_status")
}
