{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2023",
        "sourceMap": true,
        "outDir": "./dist",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": false,
        "noImplicitAny": true,
        "strictBindCallApply": true,
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": ["node", "jest"],
        "paths": {
            "@slovo/common": ["./libs/common/src"],
            "@slovo/common/*": ["./libs/common/src/*"],
            "@slovo/database": ["./libs/database/src"],
            "@slovo/database/*": ["./libs/database/src/*"],
            "@slovo/llm": ["./libs/llm/src"],
            "@slovo/llm/*": ["./libs/llm/src/*"],
            "@slovo/storage": ["./libs/storage/src"],
            "@slovo/storage/*": ["./libs/storage/src/*"],
            "@slovo/flowise-flowdata": ["./libs/flowise-flowdata/src"],
            "@slovo/flowise-flowdata/*": ["./libs/flowise-flowdata/src/*"]
        }
    }
}
