# Prisma
prisma/migrations/dev.db*
# libs/database/src/generated/ — DTO-генератор prisma-generator-nestjs-dto.
# Коммитим как артефакт: стабильные билды, CI без prisma generate, видимость DTO-изменений в PR.
# Ручные правки внутри запрещены — перегенерируется при npm run prisma:generate.

# Testing
.jest-cache/

# Build
*.tsbuildinfo
.turbo/

# Claude Code
.claude/settings.local.json

# Временные изображения для тестов в root (перемещаются в docs/experiments/)
/image*.webp
/image*.png
/image*.jpg

# Артефакты экспериментов — sample data, base64-картинки, готовые JSON-payload'ы
# для curl, дампы ответов API. Reproducible recipe лежит в docs/experiments/<name>/
# lab journal'е, сами артефакты локальные и в git не идут.
/experiments/

# Playwright MCP временные snapshot'ы / screenshot'ы.
.playwright-mcp/
