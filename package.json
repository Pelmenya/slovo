{
    "name": "slovo",
    "version": "0.1.0",
    "private": true,
    "description": "AI-platform на NestJS для прототипирования и production LLM-фичей",
    "license": "UNLICENSED",
    "workspaces": [
        "apps/*",
        "libs/*"
    ],
    "engines": {
        "node": ">=24.15.0",
        "npm": ">=11.12.1"
    },
    "scripts": {
        "build": "nest build",
        "build:api": "nest build api",
        "build:worker": "nest build worker",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
        "start": "nest start api",
        "start:dev": "node scripts/ensure-utf8.cjs && nest start api --watch",
        "start:worker:dev": "node scripts/ensure-utf8.cjs && nest start worker --watch",
        "start:prod": "node dist/apps/api/main",
        "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
        "test": "jest --passWithNoTests",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./apps/api/test/jest-e2e.json",
        "prisma:generate": "prisma generate",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "infra:up": "docker compose -f docker-compose.infra.yml up -d",
        "infra:down": "docker compose -f docker-compose.infra.yml down",
        "tools:up": "docker compose -f docker-compose.tools.yml up -d",
        "tools:down": "docker compose -f docker-compose.tools.yml down",
        "langfuse:up": "docker compose -f docker-compose.langfuse.yml up -d",
        "langfuse:down": "docker compose -f docker-compose.langfuse.yml down",
        "prepare": "husky"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.90.0",
        "@nestjs/common": "^11.1.19",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.19",
        "@nestjs/microservices": "^11.1.19",
        "@nestjs/platform-express": "^11.1.19",
        "@nestjs/swagger": "^11.3.2",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "amqp-connection-manager": "^4.1.14",
        "amqplib": "^1.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "eventsource-parser": "^3.0.0",
        "ioredis": "^5.4.0",
        "nestjs-pino": "^4.6.1",
        "pg": "^8.20.0",
        "pino-http": "^10.3.0",
        "pino-pretty": "^11.3.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@nestjs/cli": "^11.0.21",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.1.19",
        "@types/amqplib": "^0.10.5",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^24.0.0",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "prettier": "^3.4.2",
        "prisma": "^7.7.0",
        "prisma-generator-nestjs-dto": "^1.1.4",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "apps/**/*.(t|j)s",
            "libs/**/*.(t|j)s",
            "!**/*.spec.ts",
            "!**/*.e2e-spec.ts",
            "!**/*.module.ts",
            "!**/main.ts",
            "!**/index.ts",
            "!libs/database/src/generated/**",
            "!**/*.dto.ts",
            "!**/dto/index.ts"
        ],
        "coverageDirectory": "./coverage",
        "coverageThreshold": {
            "global": {
                "branches": 80,
                "functions": 80,
                "lines": 80,
                "statements": 80
            }
        },
        "testEnvironment": "node",
        "moduleNameMapper": {
            "^@slovo/common(.*)$": "<rootDir>/libs/common/src$1",
            "^@slovo/database(.*)$": "<rootDir>/libs/database/src$1",
            "^@slovo/llm(.*)$": "<rootDir>/libs/llm/src$1"
        }
    }
}
